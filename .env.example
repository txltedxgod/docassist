# ---- Application ----
APP_NAME=DocAssist
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true

# Public base URL used to build downloadable source links returned by /chat.
PUBLIC_BASE_URL=http://localhost:8000

# ---- HTTP server ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Database ----
# Async driver (used by the app), sync driver (used by Alembic).
DATABASE_URL=postgresql+asyncpg://docassist:docassist@localhost:5432/docassist
DATABASE_URL_SYNC=postgresql+psycopg://docassist:docassist@localhost:5432/docassist
DB_ECHO=false

# ---- Object storage (uploaded originals) ----
STORAGE_DIR=./var/storage
MAX_UPLOAD_MB=25
UPLOAD_ALLOWED_EXTENSIONS=pdf,docx,txt,md

# ---- LLM / Embeddings (OpenAI-compatible) ----
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
REQUEST_TIMEOUT=60

# Retry policy for transient LLM/embedding failures.
LLM_MAX_RETRIES=4
LLM_BACKOFF_BASE=0.5
LLM_BACKOFF_MAX=8.0

# ---- RAG ----
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=100
RETRIEVAL_TOP_K=5
MAX_CONTEXT_TOKENS=3000

# ---- Background ingestion ----
INGESTION_WORKERS=2
INGESTION_QUEUE_MAXSIZE=100

# ---- Telegram bot ----
TELEGRAM_BOT_TOKEN=
API_BASE_URL=http://app:8000
TELEGRAM_REQUEST_TIMEOUT=120
